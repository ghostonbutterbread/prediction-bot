# Prediction Market Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# === Kalshi ===
KALSHI_API_KEY_ID=              # Your Kalshi API key ID
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key  # Path to private key file
KALSHI_USE_DEMO=true            # true = demo mode (safe), false = real money!

# === OpenRouter Researcher ===
OPENROUTER_API_KEY=             # Get from https://openrouter.ai/keys
OPENROUTER_MODEL=google/gemini-2.5-flash   # Fast model for researcher calls

# === Strategy ===
MIN_EDGE=0.015                  # Minimum 1.5% edge to trade
MIN_CONFIDENCE=0.50             # Minimum 50% confidence
ENABLE_SOCIAL=true
ENABLE_NEWS=true

# === Kalshi Fee ===
KALSHI_FEE_RATE=0.07            # 7% fee on winnings (deducted from Kelly EV calc)

# === Risk Management ===
KELLY_FRACTION=0.5              # 0.5 = half Kelly (conservative), 0.75 = aggressive
MAX_POSITION_PCT=0.10           # Max 10% of balance per trade
DAILY_LOSS_LIMIT_PCT=20         # Stop if down 20% today
MAX_DRAWDOWN_PCT=50             # Pause if down 50% from peak
MAX_OPEN_POSITIONS=10           # Max concurrent trades

# === Sports Mode ===
ENABLE_SPORTS=true
SPORTS_MAX_HOURS=48             # Only bet on events closing within 48h

# === Logging ===
LOG_DIR=data
