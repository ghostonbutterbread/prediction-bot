# Prediction Market Trading Bot — Environment Variables

# === Kalshi ===
# Get demo keys: https://demo.kalshi.co → Settings → API
# Get live keys: https://kalshi.com → Settings → API
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key
KALSHI_USE_DEMO=true

# === Strategy ===
MIN_EDGE=0.05           # Minimum 5% edge to trade
MIN_CONFIDENCE=0.50     # Minimum 50% confidence
NEWS_WEIGHT=0.30        # News sentiment weight in ensemble
ENABLE_NEWS=true        # Enable news feed analysis

# === Risk Management ===
KELLY_FRACTION=0.5      # Half Kelly (safer)
MAX_POSITION_PCT=0.10   # Max 10% of balance per trade

# === Logging ===
LOG_DIR=data
